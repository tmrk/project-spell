{
  "name": "project-spell",
  "version": "1.6.0",
  "description": "A calm, playful spelling game for children.",
  "homepage": "https://tmrk.github.io/project-spell",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
